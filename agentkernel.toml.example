# agentkernel configuration (copy to agentkernel.toml).
# Precedence: explicit args > AGENTKERNEL_* env vars > this file > defaults.
# API keys are read ONLY from the environment (ANTHROPIC_API_KEY, OPENAI_API_KEY,
# …) and must never be placed here.

provider = "anthropic"            # "anthropic" | "openai" | "local"
model = "claude-sonnet-4-6"
# base_url = "http://localhost:11434/v1"   # for provider = "local"

max_output_tokens = 4096
output_reserve = 8192
max_iterations = 25
keep_recent_turns = 6
max_tool_result_tokens = 4096

approval_policy = "always_ask"    # always_ask | auto_allow | deny_mutations | smart
# approval_allowlist = []             # patterns that skip the gate
# approval_judge_model = "claude-haiku-4-5-20251001"  # risk judge for approval_policy = "smart"
# redact_tool_output = true           # scrub secret-looking strings from tool output (default on)
# checkpoints = true                  # back up files before edits; adds a `rollback` tool
# plan_mode = false                   # batch-approve all tools at once
working_dir = "."

# Execution sandbox for bash/code (design §10.3).
#   "local"  — subprocess confined to working_dir (cwd-scoped, not a jail)
#   "docker" — one isolated container per project (no network, bounded resources)
sandbox = "local"
# sandbox_image = "python:3.12-slim"   # image for sandbox = "docker"
# sandbox_network = "none"             # "none" | "bridge" | a named network
# summarizer_model = "claude-haiku-4-5-20251001"   # cheap model for compaction (M2)
log_dir = ".agentkernel/traces"
# mcp_log_dir = ".agentkernel/mcp-logs"  # per-server stderr logs

# Per-run guardrails (the run stops cleanly when a ceiling is exceeded).
# max_cost_usd = 0.50
# max_input_tokens_per_run = 200000

# Profiles (Phase 5): a named run parameterization loaded from profile_dir.
# profile = "reviewer"
# profile_dir = "profiles"

# Memory (Phase 3): persist/recall conversation across runs.
# memory_store = "file"             # "file" | "sqlite" | "memory"
# memory_dir = ".agentkernel/memory"
# memory_notes_path = ".agentkernel/memory/notes.jsonl"
#                                     # use a .db extension for SQLite-backed notes
# enable_memory_tools = false       # remember/recall/forget tools
# memory_auto_context = false       # auto-inject recalled notes into user message
# memory_auto_context_limit = 3     # max notes per auto-recall
# memory_store_budget = 4000        # summarize older turns before persisting

# semantic_search = false            # rank note recall with dense embeddings (SQLite only)
# semantic_search_lsh_bits = 16      # approximate vector index; omit for brute force
# embedding_model = "text-embedding-3-small"
# embedding_base_url = "http://localhost:11434/v1"  # OpenAI-compatible endpoint
# embedding_api_key_env = "OPENAI_API_KEY"

# Skills (Phase 4): Anthropic-style SKILL.md skills discovered from skills_dir.
# Each skill is a folder with a SKILL.md (YAML frontmatter: name, description;
# markdown body; optional bundled files). Only name+description are disclosed up
# front; the model loads a skill's body on demand via the use_skill tool. List
# names in `skills` to pin their full body into the prompt. See examples/skills/.
# skills_dir = "skills"
# skills = ["code-review"]          # pinned (always-on) skill names

# Loops (loop engineering) are run from the CLI, not configured here:
#   agentkernel loop --file examples/loops/until-tests-pass.toml
#   agentkernel loop --skill <skill-name> --check "uv run pytest -q" --streak 3

# Knowledge graph (Phase 6): exposes graph_add / graph_query tools.
# enable_graph = true
# graph_path = ".agentkernel/graph.jsonl"

# Self-improvement (Phase 7): where `agentkernel improve` writes rule notes.
# improvements_dir = ".agentkernel/improvements"

# Sub-agents: register a `spawn` tool so the model can delegate to children.
# enable_spawn = true
# spawn_max_depth = 2

# Evaluators (`agentkernel eval --suite suite.toml`): judge-scored runs.
# judge_model = "claude-haiku-4-5-20251001"   # defaults to `model`
# eval_threshold = 0.6
# eval_rubric = "The answer is correct and complete."

# An eval suite is a separate TOML file, e.g. suite.toml:
#   rubric = "The answer is correct and complete."   # default for all cases
#   [[cases]]
#   name = "arithmetic"
#   prompt = "What is 17 * 23?"
#   rubric = "States 391."                            # optional per-case override

# MCP servers (Phase 2). Each is launched over stdio; its tools register into
# the same registry as the builtins. Read-only tools (readOnlyHint) skip the
# approval gate; everything else is gated by default.
# [[mcp_servers]]
# name = "filesystem"
# command = "npx"
# args = ["-y", "@modelcontextprotocol/server-filesystem", "."]
# timeout = 30                       # request timeout in seconds
#
# [[mcp_servers]]
# name = "git"
# command = "uvx"
# args = ["mcp-server-git"]
